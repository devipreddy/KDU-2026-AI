{
  "version": "1.0",
  "name": "travel-booking-options",
  "template": "{\n  \"type\": \"Basic\",\n  \"children\": [\n    {\n      \"type\": \"Col\",\n      \"gap\": \"lg\",\n      \"children\": [\n        {\n          \"type\": \"Title\",\n          \"value\": \"Trips for {{ query }}\",\n          \"size\": \"2xl\"\n        },\n        {\n          \"type\": \"Caption\",\n          \"value\": \"The backend generated these offers and the frontend only renders the client-handled Book Now action.\",\n          \"color\": \"secondary\"\n        }{% for offer in offers %},\n        {\n          \"type\": \"Box\",\n          \"direction\": \"col\",\n          \"gap\": \"md\",\n          \"padding\": \"lg\",\n          \"border\": 1,\n          \"radius\": \"xl\",\n          \"background\": \"surface-secondary\",\n          \"children\": [\n            {\n              \"type\": \"Row\",\n              \"justify\": \"between\",\n              \"align\": \"start\",\n              \"children\": [\n                {\n                  \"type\": \"Col\",\n                  \"gap\": \"xs\",\n                  \"children\": [\n                    {\n                      \"type\": \"Title\",\n                      \"value\": \"{{ offer.title }}\",\n                      \"size\": \"lg\"\n                    },\n                    {\n                      \"type\": \"Caption\",\n                      \"value\": \"{{ offer.origin }} to {{ offer.destination }} via {{ offer.airline }}\",\n                      \"color\": \"secondary\"\n                    },\n                    {\n                      \"type\": \"Caption\",\n                      \"value\": \"{{ offer.nights }} nights at {{ offer.hotel }}\",\n                      \"color\": \"secondary\"\n                    }\n                  ]\n                },\n                {\n                  \"type\": \"Badge\",\n                  \"label\": \"{{ offer.price_display }}\",\n                  \"color\": \"success\",\n                  \"variant\": \"soft\"\n                }\n              ]\n            },\n            {\n              \"type\": \"Col\",\n              \"gap\": \"2xs\",\n              \"children\": [\n                {% for highlight in offer.highlights %}\n                {\n                  \"type\": \"Text\",\n                  \"value\": \"- {{ highlight }}\",\n                  \"size\": \"sm\"\n                }{% if not loop.last %},{% endif %}\n                {% endfor %}\n              ]\n            },\n            {\n              \"type\": \"Button\",\n              \"label\": \"Book Now\",\n              \"block\": true,\n              \"color\": \"success\",\n              \"variant\": \"solid\",\n              \"onClickAction\": {\n                \"type\": \"travel.book_now\",\n                \"payload\": {\n                  \"offer_id\": \"{{ offer.id }}\"\n                },\n                \"handler\": \"client\",\n                \"loadingBehavior\": \"self\"\n              }\n            }\n          ]\n        }{% endfor %}\n      ]\n    }\n  ]\n}"
}

